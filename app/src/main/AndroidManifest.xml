<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Normal permission, auto-granted on SDK 33+; declared explicitly for API hygiene. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".CalculatorApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calculator.Splash">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- We don't ship a baseline profile or call ProfileInstaller; the
             receiver/initializer get pulled in transitively by androidx.activity
             and Compose. Strip them so no system component pings dead code.
             `tools:ignore="MissingClass"` is needed because we removed the
             profileinstaller dep, so the class isn't on our classpath anymore. -->
        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            tools:node="remove"
            tools:ignore="MissingClass" />

        <!-- Single-process app; we never call enableMultiInstanceInvalidation(). -->
        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            tools:node="remove" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            tools:node="merge"
            tools:ignore="MissingClass,ExportedContentProvider">
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
